import React, { useState } from 'react';
import {
  StyleSheet,
  Text,
  View,
  TouchableOpacity,
  Modal,
  TextInput,
  ScrollView,
  Alert,
  Linking,
  Dimensions,
} from 'react-native';

const locations = [
  { name: 'Labs', message: 'Labs Location: Building A, Room 101' },
  { name: 'Classroom', message: 'Classroom Location: Ground Floor, Old Academic Block' },
  { name: 'ATM', message: 'https://maps.app.goo.gl/SaCWUqNs5CcWPoE49' }, // open link
  { name: 'Cafeteria', message: 'Cafeteria Location: Central Campus Area' },
  { name: 'Library', message: 'Library Location: Building B, 2nd Floor' },
];

const grades = [
  { label: 'O', value: 10 },
  { label: 'E', value: 9 },
  { label: 'A', value: 8 },
  { label: 'B', value: 7 },
  { label: 'C', value: 6 },
  { label: 'D', value: 5 },
  { label: 'F', value: 0 },
];

export default function App() {
  const [showLocationOptions, setShowLocationOptions] = useState(false);
  const [showSGPAModal, setShowSGPAModal] = useState(false);
  const [subjectCount, setSubjectCount] = useState('1');
  const [subjects, setSubjects] = useState([
    { grade: 10, credits: '3' },
  ]);
  const [sgpaResult, setSgpaResult] = useState(null);

  // Update subjects array when subjectCount changes
  const updateSubjectCount = (countStr) => {
    let count = parseInt(countStr, 10);
    if (isNaN(count) || count < 1) count = 1;
    setSubjectCount(count.toString());
    const newSubjects = [...subjects];
    while (newSubjects.length < count) {
      newSubjects.push({ grade: 10, credits: '3' });
    }
    while (newSubjects.length > count) {
      newSubjects.pop();
    }
    setSubjects(newSubjects);
  };

  const updateSubjectGrade = (index, gradeValue) => {
    const newSubjects = [...subjects];
    newSubjects[index].grade = gradeValue;
    setSubjects(newSubjects);
  };

  const updateSubjectCredits = (index, creditsValue) => {
    const newSubjects = [...subjects];
    newSubjects[index].credits = creditsValue;
    setSubjects(newSubjects);
  };

  const calculateSGPA = () => {
    let totalCredits = 0;
    let totalPoints = 0;
    for (let i = 0; i < subjects.length; i++) {
      const gradeValue = subjects[i].grade;
      const creditValue = parseInt(subjects[i].credits, 10);
      if (isNaN(creditValue) || creditValue <= 0) {
        Alert.alert('Invalid Input', 'Please enter valid credits for all subjects.');
        return;
      }
      totalPoints += gradeValue * creditValue;
      totalCredits += creditValue;
    }
    if (totalCredits === 0) {
      Alert.alert('Invalid Input', 'Total credits cannot be zero.');
      return;
    }
    const sgpa = totalPoints / totalCredits;
    setSgpaResult(sgpa.toFixed(2));
  };

  const openLink = (url) => {
    Linking.openURL(url).catch(() => {
      Alert.alert('Error', 'Failed to open link.');
    });
  };

  const handleLocationPress = (location) => {
    if (location.name === 'ATM') {
      openLink(location.message);
    } else {
      Alert.alert(location.name, location.message);
    }
  };

  const windowHeight = Dimensions.get('window').height;

  return (
    <View style={styles.container}>
      {/* Nav Bar */}
      <View style={styles.nav}>
        <Text style={styles.logo}>CAMPNAV</Text>
        <View style={styles.menu}>
          <TouchableOpacity onPress={() => Alert.alert('Home')}>
            <Text style={styles.menuItem}>Home</Text>
          </TouchableOpacity>
          <TouchableOpacity onPress={() => Alert.alert('About')}>
            <Text style={styles.menuItem}>About</Text>
          </TouchableOpacity>
          <TouchableOpacity onPress={() => Alert.alert('Help Desk')}>
            <Text style={styles.menuItem}>Help Desk</Text>
          </TouchableOpacity>
        </View>
      </View>

      {/* Main Content */}
      <ScrollView contentContainerStyle={styles.content}>

        <Text style={styles.welcomeText}>
          Welcome to <Text style={{ color: '#79d8bc' }}>IGIT</Text> Sarang
        </Text>
        <Text style={styles.description}>
          Indira Gandhi Institute of Technology (IGIT), Sarang offers various engineering programs.
        </Text>

        <TouchableOpacity
          style={styles.button}
          onPress={() => openLink('https://www.canva.com/design/DAGgpunYfO4/fZBNxCraC2Zopm2pMh4fqQ/view?utm_content=DAGgpunYfO4&utm_campaign=designshare&utm_medium=link2&utm_source=uniquelinks&utlId=h0ebaea2252')}
        >
          <Text style={styles.buttonText}>Presentation</Text>
        </TouchableOpacity>

        <TouchableOpacity
          style={[styles.button, styles.locationButton]}
          onPress={() => setShowLocationOptions(!showLocationOptions)}
        >
          <Text style={[styles.buttonText, { color: 'black' }]}>Maps</Text>
        </TouchableOpacity>

        <TouchableOpacity
          style={styles.button}
          onPress={() => {
            setShowSGPAModal(true);
            updateSubjectCount(subjectCount);
            setSgpaResult(null);
          }}
        >
          <Text style={styles.buttonText}>SGPA Calculator</Text>
        </TouchableOpacity>

        <TouchableOpacity
          style={styles.button}
          onPress={() => openLink('https://www.speedtest.net')}
        >
          <Text style={styles.buttonText}>Internet Speed Check</Text>
        </TouchableOpacity>

        <TouchableOpacity
          style={styles.button}
          onPress={() => openLink('https://chat.openai.com')}
        >
          <Text style={styles.buttonText}>AI Bot</Text>
        </TouchableOpacity>

        <TouchableOpacity
          style={styles.button}
          onPress={() => openLink('https://igit.icrp.in/')}
        >
          <Text style={styles.buttonText}>ERP Portal</Text>
        </TouchableOpacity>

        {/* Spacer for scroll */}
        <View style={{ height: 300 }} />
      </ScrollView>

      {/* Location Options */}
      {showLocationOptions && (
        <View style={styles.locationOptions}>
          {locations.map((loc, idx) => (
            <TouchableOpacity
              key={idx}
              style={[styles.button, styles.locationButton]}
              onPress={() => {
                handleLocationPress(loc);
                setShowLocationOptions(false);
              }}
            >
              <Text style={[styles.buttonText, { color: 'black' }]}>{loc.name}</Text>
            </TouchableOpacity>
          ))}
        </View>
      )}

      {/* SGPA Calculator Modal */}
      <Modal
        visible={showSGPAModal}
        animationType="slide"
        transparent={true}
        onRequestClose={() => setShowSGPAModal(false)}
      >
        <View style={styles.modalOverlay}>
          <View style={styles.sgpaModal}>
            <TouchableOpacity
              style={styles.closeBtn}
              onPress={() => setShowSGPAModal(false)}
            >
              <Text style={{ color: 'white', fontWeight: 'bold', fontSize: 18 }}>×</Text>
            </TouchableOpacity>
            <Text style={styles.modalTitle}>SGPA Calculator</Text>

            <Text style={styles.label}>Number of Subjects:</Text>
            <TextInput
              style={styles.input}
              keyboardType="numeric"
              value={subjectCount}
              onChangeText={updateSubjectCount}
              maxLength={2}
            />

            <ScrollView style={{ maxHeight: 200, marginVertical: 10 }}>
              {subjects.map((subj, i) => (
                <View key={i} style={styles.subjectRow}>
                  <View style={{ flex: 1 }}>
                    <Text style={styles.label}>Subject {i + 1} Grade:</Text>
                    <ScrollView horizontal showsHorizontalScrollIndicator={false}>
                      {grades.map((g) => (
                        <TouchableOpacity
                          key={g.value}
                          style={[
                            styles.gradeOption,
                            subj.grade === g.value && styles.gradeSelected,
                          ]}
                          onPress={() => updateSubjectGrade(i, g.value)}
                        >
                          <Text style={subj.grade === g.value ? styles.gradeSelectedText : styles.gradeText}>
                            {g.label}
                          </Text>
                        </TouchableOpacity>
                      ))}
                    </ScrollView>
                  </View>
                  <View style={{ flex: 1, marginLeft: 10 }}>
                    <Text style={styles.label}>Credits:</Text>
                    <TextInput
                      style={styles.input}
                      keyboardType="numeric"
                      value={subj.credits}
                      onChangeText={(val) => updateSubjectCredits(i, val)}
                      maxLength={2}
                    />
                  </View>
                </View>
              ))}
            </ScrollView>

            <TouchableOpacity style={styles.calculateBtn} onPress={calculateSGPA}>
              <Text style={styles.buttonText}>Calculate SGPA</Text>
            </TouchableOpacity>

            {sgpaResult && (
              <Text style={styles.sgpaResult}>SGPA: {sgpaResult}</Text>
            )}
          </View>
        </View>
      </Modal>

      {/* Sidebar (bottom fixed buttons for mobile) */}
      <View style={styles.sidebar}>
        <TouchableOpacity style={styles.sidebarBtn} onPress={() => Alert.alert('Sidebar Button 1')}>
          <Text style={styles.sidebarBtnText}>Button 1</Text>
        </TouchableOpacity>
        <TouchableOpacity style={styles.sidebarBtn} onPress={() => Alert.alert('Sidebar Button 2')}>
          <Text style={styles.sidebarBtnText}>Button 2</Text>
        </TouchableOpacity>
        <TouchableOpacity style={styles.sidebarBtn} onPress={() => Alert.alert('Sidebar Button 3')}>
          <Text style={styles.sidebarBtnText}>Button 3</Text>
        </TouchableOpacity>
      </View>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    backgroundColor: '#090a0f', // night sky background
  },
  nav: {
    height: 80,
    backgroundColor: 'rgba(0,0,0,0.3)',
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingHorizontal: 20,
    paddingTop: 30,
  },
  logo: {
    fontSize: 30,
    fontWeight: 'bold',
    color: '#fff',
  },
  menu: {
    flexDirection: 'row',
    gap: 20,
  },
  menuItem: {
    color: '#fff',
    fontSize: 16,
    marginHorizontal: 10,
  },
  content: {
    padding: 20,
    paddingTop: 40,
    alignItems: 'center',
  },
  welcomeText: {
    fontSize: 24,
    fontWeight: 'bold',
    marginBottom: 10,
    color: '#fff',
  },
  description: {
    fontSize: 16,
    marginBottom: 20,
    color: '#ddd',
    textAlign: 'center',
  },
  button: {
    backgroundColor: '#1500ff',
    paddingVertical: 15,
    paddingHorizontal: 30,
    borderRadius: 10,
    marginVertical: 8,
    width: '80%',
    alignItems: 'center',
    shadowColor: '#000',
    shadowOpacity: 0.3,
    shadowRadius: 5,
  },
  buttonText: {
    color: '#fff',
    fontWeight: 'bold',
    fontSize: 18,
  },
  locationButton: {
    backgroundColor: 'gray',
  },
  locationOptions: {
    position: 'absolute',
    top: 100,
    left: '50%',
    transform: [{ translateX: -0.5 * Dimensions.get('window').width * 0.8 }],
    width: '80%',
    backgroundColor: 'rgba(255,255,255,0.9)',
    borderRadius: 10,
    padding: 10,
    zIndex: 100,
    alignItems: 'center',
  },
  modalOverlay: {
    flex: 1,
    backgroundColor: 'rgba(0,0,0,0.6)',
    justifyContent: 'center',
    alignItems: 'center',
  },
  sgpaModal: {
    backgroundColor: 'white',
    width: '90%',
    borderRadius: 10,
    padding: 20,
    maxHeight: '80%',
  },
  closeBtn: {
    position: 'absolute',
    top: 10,
    right: 10,
    backgroundColor: 'red',
    borderRadius: 15,
    width: 30,
    height: 30,
    justifyContent: 'center',
    alignItems: 'center',
    zIndex: 10,
  },
  modalTitle: {
    fontSize: 22,
    fontWeight: 'bold',
    marginBottom: 15,
    textAlign: 'center',
  },
  label: {
    fontSize: 16,
    marginTop: 10,
    marginBottom: 5,
  },
  input: {
    borderWidth: 1,
    borderColor: '#999',
    borderRadius: 5,
    paddingHorizontal: 10,
    paddingVertical: 5,
    fontSize: 16,
  },
  subjectRow: {
    flexDirection: 'row',
    marginBottom: 15,
    alignItems: 'center',
  },
  gradeOption: {
    paddingHorizontal: 10,
    paddingVertical: 5,
    borderRadius: 5,
    borderWidth: 1,
    borderColor: '#1500ff',
    marginRight: 8,
  },
  gradeSelected: {
    backgroundColor: '#1500ff',
  },
  gradeText: {
    color: '#1500ff',
    fontWeight: 'bold',
  },
  gradeSelectedText: {
    color: 'white',
    fontWeight: 'bold',
  },
  calculateBtn: {
    backgroundColor: '#04f6fe',
    paddingVertical: 12,
    borderRadius: 10,
    marginTop: 10,
    alignItems: 'center',
  },
  sgpaResult: {
    marginTop: 15,
    fontSize: 18,
    fontWeight: 'bold',
    textAlign: 'center',
  },
  sidebar: {
    position: 'absolute',
    bottom: 0,
    width: '100%',
    backgroundColor: 'rgba(0,0,0,0.3)',
    flexDirection: 'row',
    justifyContent: 'space-around',
    paddingVertical: 10,
  },
  sidebarBtn: {
    backgroundColor: '#1500ff',
    paddingVertical: 10,
    paddingHorizontal: 15,
    borderRadius: 5,
  },
  sidebarBtnText: {
    color: 'white',
    fontWeight: 'bold',
  },
});
